APP_URL="http://localhost:3000"

# Prisma CLI and legacy seed script only. The application runtime uses the DB
# binding declared in wrangler.jsonc (local D1 under .wrangler/state).
DATABASE_URL="file:./prisma/dev.db"

# Production on Vercel only. Leave unset for local development so the app
# keeps using the D1 binding simulated by Wrangler.
CLOUDFLARE_D1_TOKEN=""
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_DATABASE_ID=""

AUTH_PROVIDER="better-auth"
AUTH_ENFORCE="false"

BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="replace-with-at-least-32-characters"
BETTER_AUTH_DATABASE_PROVIDER="sqlite"

NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""

STORAGE_PROVIDER="r2"
R2_MAX_UPLOAD_BYTES="10485760"
LOCAL_UPLOAD_DIR="./storage/uploads"
SUPABASE_STORAGE_BUCKET="wedding-media"

RESEND_API_KEY=""
EMAIL_FROM="Nuptia <hola@nuptia.local>"

SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://localhost:3000/api/integrations/spotify/callback"
