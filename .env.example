APP_URL="http://localhost:3000"

# Current local runtime uses SQLite.
# Future external databases require changing prisma/schema.prisma datasource provider,
# core/db driver adapter, DATABASE_URL and migrations explicitly:
# PostgreSQL/Supabase Postgres: postgresql://user:password@host:5432/db
# MariaDB/MySQL: mysql://user:password@host:3306/db
DATABASE_URL="file:./prisma/dev.db"

AUTH_PROVIDER="better-auth"
AUTH_ENFORCE="false"

BETTER_AUTH_URL="http://localhost:3000"
BETTER_AUTH_SECRET="replace-with-at-least-32-characters"
BETTER_AUTH_DATABASE_PROVIDER="sqlite"

NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_SECRET_KEY=""

STORAGE_PROVIDER="local"
LOCAL_UPLOAD_DIR="./storage/uploads"
SUPABASE_STORAGE_BUCKET="wedding-media"

RESEND_API_KEY=""
EMAIL_FROM="Nuptia <hola@nuptia.local>"

SPOTIFY_CLIENT_ID=""
SPOTIFY_CLIENT_SECRET=""
SPOTIFY_REDIRECT_URI="http://localhost:3000/api/integrations/spotify/callback"
